{
  "name": "Sibility",
  "version": "0.1.0",
  "description": "Installable React component and CLI for karaoke-style read-along with OpenAI TTS",
  "author": "Devon Crebbin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcrebbin/sibility"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18"
  }
}
